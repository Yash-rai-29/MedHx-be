# GCP Configurations
GCP_PROJECT_ID=ai-health-companion
GCP_REGION=asia-south1
FIREBASE_PROJECT_ID=ai-health-companion
STORAGE_BUCKET_NAME=ai-health-media
GCS_SIGNING_SERVICE_ACCOUNT=export-sa@ai-health-companion.iam.gserviceaccount.com

# Vertex AI / Gemini Config
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=your_gemini_api_key_here

# Document AI Configuration
DOCUMENT_AI_PROCESSOR_NAME=projects/your-project-id/locations/us/processors/your-processor-id

# Environment Mode (development / production)
ENVIRONMENT=development

# Google application credentials JSON path (if running locally outside GCP)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
